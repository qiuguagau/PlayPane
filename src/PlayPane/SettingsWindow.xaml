<Window x:Class="PlayPane.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PlayPane Settings"
        Width="520"
        Height="360"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource PanelBackgroundBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel>
            <TextBlock x:Name="StartupLabel" Text="Startup" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />
            <TextBlock x:Name="LanguageLabel" Text="Language" Margin="4,0,4,0" />
            <ComboBox x:Name="LanguageComboBox" Margin="4,4,4,12">
                <ComboBoxItem x:Name="EnglishItem" Tag="English" Content="English" />
                <ComboBoxItem x:Name="SimplifiedChineseItem" Tag="SimplifiedChinese" Content="Simplified Chinese" />
            </ComboBox>
            <CheckBox x:Name="StartWithWindowsCheckBox" Content="Start with Windows" IsEnabled="False" />
            <TextBlock x:Name="GlobalShortcutsLabel" Text="Global shortcuts" FontSize="18" FontWeight="SemiBold" Margin="0,24,0,8" />
            <TextBlock x:Name="ShortcutToggleOverlayText" Text="Ctrl + Alt + O: Show or hide overlay" />
            <TextBlock x:Name="ShortcutToggleModeText" Text="Ctrl + Alt + E: Switch Edit/Game Mode" />
            <TextBlock x:Name="ShortcutOpacityText" Text="Ctrl + Alt + Up/Down: Adjust opacity" />
            <TextBlock x:Name="ShortcutStopText" Text="Ctrl + Alt + Q: Stop mirroring" />
        </StackPanel>
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="SaveButton" Content="Save" Click="SaveButton_Click" Background="#2B6EF3" Foreground="White" />
            <Button x:Name="CancelButton" Content="Cancel" Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</Window>
