<Window x:Class="PlayPane.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="PlayPane"
        Width="960"
        Height="640"
        MinWidth="860"
        MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource PanelBackgroundBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="True" Margin="0,0,0,12">
            <Button x:Name="SettingsButton" DockPanel.Dock="Right" Content="Settings" Click="SettingsButton_Click" />
            <StackPanel>
                <TextBlock Text="PlayPane" FontSize="24" FontWeight="SemiBold" />
                <TextBlock x:Name="SubtitleTextBlock" Text="Mirror a Chrome or Edge tab through the PlayPane extension" Foreground="#5A6475" />
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="340" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" BorderBrush="#D8DEE9" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock x:Name="PreviewTitleTextBlock" Text="Extension Preview" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <TextBlock x:Name="PreviewStatusTextBlock" DockPanel.Dock="Right" Text="Waiting" Foreground="#5A6475" VerticalAlignment="Center" />
                    </DockPanel>

                    <Border Grid.Row="1" Background="#020617" BorderBrush="#2F3747" BorderThickness="1">
                        <wv2:WebView2 x:Name="PreviewWebView" />
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="White" BorderBrush="#D8DEE9" BorderThickness="1" CornerRadius="6" Padding="12">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock x:Name="ExtensionLabelTextBlock" Text="Chrome/Edge Extension" FontWeight="SemiBold" Margin="0,0,0,6" />
                        <TextBlock x:Name="ExtensionStatusTextBlock" TextWrapping="Wrap" Foreground="#5A6475" />
                        <TextBlock x:Name="SignalingAddressLabel" Text="Local signaling address" FontWeight="SemiBold" Margin="0,14,0,6" />
                        <TextBox x:Name="SignalingAddressTextBox" IsReadOnly="True" />

                        <TextBlock x:Name="InstructionsLabel" Text="How to connect" FontWeight="SemiBold" Margin="0,16,0,6" />
                        <TextBlock x:Name="InstructionsTextBlock" TextWrapping="Wrap" Foreground="#3D4758" />

                        <Separator Margin="0,18,0,14" />

                        <TextBlock x:Name="FrameRateLabel" Text="Frame rate" Margin="4,0,4,0" />
                        <ComboBox x:Name="FrameRateComboBox" SelectionChanged="FrameRateComboBox_SelectionChanged">
                            <ComboBoxItem x:Name="FrameRateLowItem" Content="Low Resource - 15 FPS" Tag="LowResource" />
                            <ComboBoxItem x:Name="FrameRateStandardItem" Content="Standard - 30 FPS" Tag="Standard" IsSelected="True" />
                            <ComboBoxItem x:Name="FrameRateSmoothItem" Content="Smooth - 60 FPS" Tag="Smooth" />
                        </ComboBox>

                        <DockPanel Margin="4,14,4,0">
                            <TextBlock x:Name="OpacityLabel" Text="Opacity" DockPanel.Dock="Left" />
                            <TextBlock x:Name="OpacityValueTextBlock" Text="80%" DockPanel.Dock="Right" />
                        </DockPanel>
                        <Slider x:Name="OpacitySlider" Minimum="10" Maximum="100" TickFrequency="5" IsSnapToTickEnabled="True" Value="80" ValueChanged="OpacitySlider_ValueChanged" />
                        <CheckBox x:Name="AspectRatioCheckBox" Content="Lock aspect ratio" IsChecked="True" Checked="AspectRatioCheckBox_Changed" Unchecked="AspectRatioCheckBox_Changed" />

                        <Separator Margin="0,18,0,14" />

                        <Button x:Name="StartOverlayButton" Content="Start Overlay" Click="StartOverlayButton_Click" Background="#2B6EF3" Foreground="White" />
                        <Button x:Name="StopMirroringButton" Content="Stop Mirroring" Click="StopMirroringButton_Click" />
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#EEF2F8" BorderBrush="#D8DEE9" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,12,0,0">
            <TextBlock x:Name="StatusTextBlock" Text="Ready" />
        </Border>
    </Grid>
</Window>
