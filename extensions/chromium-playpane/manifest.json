{
  "manifest_version": 3,
  "name": "PlayPane Capture",
  "description": "Capture the current Chrome or Edge tab and stream frames to the PlayPane desktop overlay.",
  "version": "0.1.0",
  "minimum_chrome_version": "116",
  "permissions": [
    "activeTab",
    "offscreen",
    "tabCapture",
    "tabs"
  ],
  "action": {
    "default_title": "PlayPane Capture",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' ws://127.0.0.1:17632;"
  }
}
