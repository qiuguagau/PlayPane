<Window x:Class="PlayPane.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PlayPane Overlay"
        Width="800"
        Height="450"
        MinWidth="240"
        MinHeight="140"
        WindowStartupLocation="Manual"
        ResizeMode="CanResizeWithGrip"
        WindowStyle="None"
        ShowInTaskbar="True"
        Topmost="False"
        Background="Transparent">
    <Border x:Name="OuterBorder" BorderBrush="#2B6EF3" BorderThickness="2" Background="#020617">
        <Grid>
            <Image x:Name="MirrorImage" Stretch="Uniform" />

            <Border x:Name="Toolbar" VerticalAlignment="Top" Background="#EFFFFFFF" BorderBrush="#B6C2D4" BorderThickness="0,0,0,1" Padding="6">
                <DockPanel LastChildFill="False" MouseLeftButtonDown="Toolbar_MouseLeftButtonDown">
                    <TextBlock x:Name="ToolbarTitle" Text="PlayPane Overlay" VerticalAlignment="Center" FontWeight="SemiBold" Margin="4,0,12,0" />
                    <TextBlock x:Name="OpacityLabel" Text="Opacity" VerticalAlignment="Center" />
                    <Slider x:Name="OpacitySlider" Width="120" Minimum="10" Maximum="100" TickFrequency="5" IsSnapToTickEnabled="True" ValueChanged="OpacitySlider_ValueChanged" Margin="6,0,12,0" />
                    <ComboBox x:Name="FrameRateComboBox" Width="150" SelectionChanged="FrameRateComboBox_SelectionChanged">
                        <ComboBoxItem Content="15 FPS" Tag="LowResource" />
                        <ComboBoxItem Content="30 FPS" Tag="Standard" IsSelected="True" />
                        <ComboBoxItem Content="60 FPS" Tag="Smooth" />
                    </ComboBox>
                    <Button x:Name="CropButton" Content="Crop" Click="CropButton_Click" />
                    <Button x:Name="LockButton" Content="Lock" Click="LockButton_Click" />
                    <Button x:Name="HideButton" Content="Hide" Click="HideButton_Click" />
                    <Button x:Name="StopButton" Content="Stop" Click="StopButton_Click" />
                </DockPanel>
            </Border>

            <Border x:Name="WarningBorder" Visibility="Collapsed" VerticalAlignment="Bottom" Margin="12" Padding="8" Background="#DDEB5646" CornerRadius="4">
                <TextBlock x:Name="WarningTextBlock" Foreground="White" />
            </Border>
        </Grid>
    </Border>
</Window>
